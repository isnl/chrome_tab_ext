{
  "manifest_version": 3,
  "name": "Fresh New Tab",
  "description": "A fresh Chrome new tab with sticky Google search, weather, and a detailed Chinese calendar.",
  "version": "0.2.0",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.ip.sb/*",
    "https://freeipapi.com/*",
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://timor.tech/*"
  ],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  }
}
